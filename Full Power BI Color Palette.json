{
  "name": "RCB Winning Formula Premium",
  "dataColors": [
    "#E30000",
    "#C40000",
    "#F7E0A3",
    "#FFFFFF",
    "#1A1A1A",
    "#900000",
    "#E6E6E6",
    "#FFD700"
  ],
  "background": "#0D0D0D",
  "foreground": "#E30000",
  "tableAccent": "#FFD700",
  "visualStyles": {
    "page": {
      "*": {
        "background": [
          {
            "color": { "solid": { "color": "#0D0D0D" } },
            "transparency": 0
          }
        ]
      }
    },
    "*": {
      "*": {
        "background": [
          {
            "show": true,
            "color": { "solid": { "color": "#1A1A1A" } },
            "transparency": 0
          }
        ],
        "border": [
          {
            "show": true,
            "color": { "solid": { "color": "#E30000" } },
            "radius": 8
          }
        ],
        "title": [
          {
            "show": true,
            "fontColor": { "solid": { "color": "#FFFFFF" } },
            "fontSize": 13,
            "fontFamily": "Segoe UI Semibold"
          }
        ],
        "labels": [
          {
            "show": true,
            "color": { "solid": { "color": "#D9D9D9" } }
          }
        ],
        "categoryAxis": [
          {
            "show": true,
            "labelColor": { "solid": { "color": "#FFFFFF" } }
          }
        ],
        "valueAxis": [
          {
            "show": true,
            "labelColor": { "solid": { "color": "#B0B0B0" } }
          }
        ]
      }
    },
    "card": {
      "*": {
        "background": [
          {
            "show": true,
            "color": { "solid": { "color": "#161616" } },
            "transparency": 0
          }
        ],
        "labels": [
          {
            "fontColor": { "solid": { "color": "#FFD700" } },
            "fontSize": 28,
            "fontFamily": "Segoe UI Bold"
          }
        ],
        "categoryLabels": [
          {
            "fontColor": { "solid": { "color": "#B0B0B0" } },
            "fontSize": 10
          }
        ]
      }
    },
    "advancedCard": {
      "*": {
        "background": [
          {
            "show": true,
            "color": { "solid": { "color": "#161616" } },
            "transparency": 0
          }
        ],
        "value": [
          {
            "fontColor": { "solid": { "color": "#FFD700" } },
            "fontSize": 28
          }
        ],
        "subtitle": [
          {
            "fontColor": { "solid": { "color": "#B0B0B0" } }
          }
        ]
      }
    }
  }
}